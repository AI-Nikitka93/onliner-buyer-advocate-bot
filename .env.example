# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PORT: HTTP port for Express/Vite.
PORT="3000"

# HTTP safety limits.
JSON_BODY_LIMIT="1mb"
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="120"

# Admin API token for channel publishing and webhook setup.
# Required for admin endpoints in NODE_ENV=production.
ADMIN_API_TOKEN="change_me_admin_token"

# RUNTIME_STATE_PATH: local persistent price snapshots and generated channel posts.
RUNTIME_STATE_PATH="data/runtime-state.json"

# Onliner live search settings.
ONLINER_SEARCH_SCHEMAS="mobile,notebook,tv,headphones,tabletpc,watch,videocard,styler"
ONLINER_POLL_QUERY="redmi"
MIN_HONEST_DISCOUNT_PERCENT="20"
ONLINER_DEAL_SCAN_LIMIT="50"
ONLINER_DEAL_SCAN_PAGES="3"
ONLINER_DEAL_ANALYZE_LIMIT="6"
ONLINER_DEAL_MIN_PRICE_BYN="50"
ONLINER_DEAL_MIN_OFFERS="2"
# Optional comma-separated superprice groups, for example:
# ONLINER_SUPERPRICE_CATEGORY_GROUPS="elektronika,kompyutery_i_seti,bytovaya_tehnika"
ONLINER_FETCH_TIMEOUT_MS="8000"
ONLINER_REVIEW_PAGES_MAX="3"

# External price pilots. Keep disabled until the source is checked and the key
# is current. 5element is price-only and must be labeled as a pilot, not as
# "all RB sites".
ENABLE_5ELEMENT_PILOT="false"
FIVE_ELEMENT_SEARCH_API_KEY="08IE0509XQ"

# Telegram delivery. Keep ENABLE_TELEGRAM_DELIVERY=false until the bot token and
# channel permissions are verified.
TELEGRAM_BOT_TOKEN="PASTE_BOTFATHER_TOKEN_HERE"
TELEGRAM_CHANNEL_ID="@your_channel_username_or_-100_id"
TELEGRAM_WEBHOOK_SECRET="change_me_to_random_secret"
ENABLE_TELEGRAM_DELIVERY="false"
ENABLE_CHANNEL_CRON="false"
AUTO_PUBLISH_CHANNEL="false"
CHANNEL_POLL_INTERVAL_MINUTES="360"
CHANNEL_POLL_ON_START="false"
DEAL_REPOST_COOLDOWN_HOURS="72"
DEAL_REPOST_PRICE_DROP_PERCENT="2"
ENABLE_PRICE_WATCHES="false"
PRICE_WATCH_DROP_PERCENT="5"
PRICE_WATCH_SCAN_LIMIT="25"
PRICE_WATCH_NOTIFY_COOLDOWN_HOURS="24"
WORKER_PUBLIC_URL="https://onliner-buyer-advocate-bot.georgaishkin.workers.dev"
PUBLIC_API_RATE_LIMIT_MAX="60"
PUBLIC_API_RATE_LIMIT_WINDOW_SECONDS="60"
